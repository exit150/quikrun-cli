{
  "name": "quikrun",
  "version": "0.1.3",
  "description": "The QuikRun CLI. Scaffold, deploy, and run serverless snippets from your terminal.",
  "type": "module",
  "bin": {
    "quikrun": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exit150/quikrun-cli.git"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "quikrun",
    "serverless",
    "snippets",
    "cli",
    "edge"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
